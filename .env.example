# Copy to .env and fill in your keys.

# Groq API key — powers the local (Llama 3.1 8B) and large (Llama 3 70B) LLM tiers.
# Get one at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API key — powers the grounded web-search route (real-time facts).
# Get one at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# --- Usage limits (protect the billed APIs on the public demo) ---
# Per-IP requests allowed per minute.
RATE_LIMIT_PER_MINUTE=20
# Global cap on total requests per day (bounds paid-API exposure).
MAX_REQUESTS_PER_DAY=500
# Set to 0 to disable the guard entirely (e.g. local dev / load testing).
RATE_LIMIT_ENABLED=1
